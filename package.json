{
  "name": "reviewphin",
  "version": "0.13.2",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.18.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
    "cli": "tsx src/cli.ts",
    "docs:build": "astro build --root docs",
    "docs:build:container": "pnpm docs:build && node scripts/publish-docs-container.mjs",
    "docs:dev": "astro dev --root docs",
    "dev": "tsx watch src/index.ts",
    "lint:fix": "eslint . --fix",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@github/copilot-sdk": "^1.0.5",
    "fastify": "^5.9.0",
    "glob": "^13.0.6",
    "octokit": "^5.0.5",
    "pino": "^10.3.1",
    "tar": "^7.5.19",
    "ulidx": "^2.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/starlight": "^0.41.3",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.19",
    "@vitest/coverage-v8": "^4.1.9",
    "astro": "^7.0.6",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "optionalDependencies": {
    "@flotiq/flotiq-api-sdk": "1.1.0"
  }
}
