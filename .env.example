PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
DATABASE_PATH=./data/review-worker.sqlite
RUN_LOG_DIR=./data/run-logs
WORKSPACE_ROOT=./tmp/review-workspaces
MAX_JOB_RETRIES=3
RETRY_BACKOFF_MS=5000
COPILOT_TIMEOUT_MS=180000
COPILOT_MODEL=gpt-5.4
# COPILOT_CLI_PATH=/usr/local/bin/copilot

# For Docker or other non-interactive runs, uncomment the following and
# use a fine-grained GitHub PAT with the "Copilot Requests" permission.
# The token owner also needs GitHub Copilot access.
# COPILOT_GITHUB_TOKEN=github_pat_replace_me
